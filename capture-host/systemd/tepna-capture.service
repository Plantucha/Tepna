[Unit]
Description=Tepna capture daemon (BLE -> vendor-layout files)
# Needs the Bluetooth stack and a synced clock (arrival stamps depend on the clock).
After=bluetooth.target network-online.target time-sync.target
Wants=bluetooth.target network-online.target

[Service]
# notify (not simple): the daemon sends READY=1 once capture is actually up, and heartbeats WATCHDOG=1
# from a live-event-loop task. WatchdogSec turns the box's signature HUNG-BUT-ALIVE failure (a wedged BLE
# stack that captures nothing while the process keeps running) into an automatic kill+restart — Restart
# alone never fires on a wedge because nothing crashes. sd_watchdog() pings at half this interval.
Type=notify
WatchdogSec=120
User=tepna
Group=tepna
WorkingDirectory=/opt/tepna/capture-host
# Use the venv's python (see README install).
ExecStart=/opt/tepna/capture-host/.venv/bin/python capture.py --config /opt/tepna/capture-host/config.yaml
Restart=always
RestartSec=5
# Capture is unattended overnight — keep it alive across transient BLE drops.
StartLimitIntervalSec=0
# Let it write under /srv/tepna; otherwise lock it down.
ReadWritePaths=/srv/tepna
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true

[Install]
WantedBy=multi-user.target
