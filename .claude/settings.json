{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-shared-tree.sh\"",
            "if": "Bash(git *)",
            "timeout": 10,
            "statusMessage": "checking shared-tree safety"
          }
        ]
      }
    ]
  }
}
