{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true, "defaultBranch": "main" },
  "files": {
    "includes": ["**/*.js", "**/*.mjs", "!**/*.min.js", "!node_modules/**", "!uploads/**", "!docs/**", "!docs-archive/**", "!scraps/**", "!papers/**", "!codegen/generated/**", "!**/*fixture*"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 200,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "none",
      "arrowParentheses": "always"
    }
  },
  "linter": { "enabled": false },
  "assist": { "enabled": false }
}
