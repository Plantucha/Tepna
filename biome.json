{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true, "defaultBranch": "main" },
  "files": {
    "includes": ["**/*.js", "**/*.mjs", "!**/*.min.js", "!node_modules/**", "!uploads/**", "!docs/**", "!docs-archive/**", "!scraps/**", "!papers/**", "!codegen/generated/**", "!**/*fixture*"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 200,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "none",
      "arrowParentheses": "always"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "correctness": {
        "noUnreachable": "error",
        "noUnsafeFinally": "error",
        "noSelfAssign": "error",
        "useIsNan": "error",
        "noUnusedVariables": "warn",
        "noConstantCondition": "error",
        "useValidTypeof": "error",
        "noGlobalObjectCalls": "error",
        "noSwitchDeclarations": "off"
      },
      "suspicious": {
        "noFallthroughSwitchClause": "error",
        "noDuplicateObjectKeys": "error",
        "noDuplicateParameters": "error",
        "noDuplicateCase": "error",
        "noAssignInExpressions": "warn",
        "noFunctionAssign": "error",
        "noUnsafeNegation": "error",
        "noCompareNegZero": "error",
        "noDoubleEquals": "warn",
        "noSparseArray": "error",
        "noSelfCompare": "error"
      }
    }
  },
  "assist": { "enabled": false },
  "overrides": [
    {
      "includes": [
        "cpapdex-render.js",
        "ecgdex-app.js",
        "glucodex-app.js",
        "integrator-app.js",
        "ppgdex-app.js",
        "pulsedex-render.js",
        "pulsedex-app.js",
        "oxydex-render.js",
        "oxydex-fusion.js",
        "oxydex-app.js",
        "hrvdex-dsp.js",
        "hrvdex-app.js"
      ],
      "formatter": { "enabled": false }
    }
  ]
}
